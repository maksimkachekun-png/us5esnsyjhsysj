def btn_check_sub(chat, uid):
    if bot.subscribed(uid):
        bot.send(chat, "✅ Подписка есть!", kbd=menu_kbd(True))
    else:
        bot.send(chat, "❌ Не подписан!", kbd=channel_kbd())

def handle_callback(query):
    cbid = query["id"]
    data = query.get("data", "")
    uid = query["from"]["id"]
    chat = query["message"]["chat"]["id"]
    mid = query["message"]["message_id"]
    
    if data == "check_sub":
        if bot.subscribed(uid):
            bot.edit(chat, mid, "✅ Готово! Можешь пользоваться ботом", kbd=menu_kbd(True))
        else:
            bot.answer(cbid, "❌ Не подписан!", alert=True)

def bot_answer(cbid, text, alert=False):
    bot.call("answerCallbackQuery", {
        "callback_query_id": cbid, "text": text, "show_alert": alert
    })

# ==================== ОСНОВНОЙ ЦИКЛ ====================
def process(update):
    try:
        if "callback_query" in update:
            handle_callback(update["callback_query"])
            return
        
        msg = update.get("message")
        if not msg or "text" not in msg:
            return
        
        chat = msg["chat"]["id"]
        text = msg["text"]
        uid = msg["from"]["id"]
        fname = msg["from"].get("first_name", "User")
        lname = msg["from"].get("last_name", "")
        username = msg["from"].get("username", "")
        fullname = f"{fname} {lname}".strip()
        
        user = db.user(uid)
        state = user.get("state", "menu")
        
        if text == "/start":
            cmd_start(chat, uid, fname)
        elif text == "/help":
            bot.send(chat, "/start - меню\n/cancel - отмена")
        elif text == "/cancel":
            db.set_user(uid, {"state": "menu", "phone": "", "api": None, "tries": 0})
            bot.send(chat, "❌ Отменено", kbd=menu_kbd(True))
        elif text == "📱 Сдать номер":
            btn_send_number(chat, uid)
        elif text == "📊 Мои номера":
            btn_my_numbers(chat, uid)
        elif text == "ℹ️ Помощь":
            bot.send(chat, "Бот для регистрации в MAX. /start")
        elif text == "✅ Проверить подписку":
            btn_check_sub(chat, uid)
        elif state == "wait_phone":
            handle_phone(chat, uid, text)
        elif state == "wait_code":
            handle_code(chat, uid, text, username, fullname)
        else:
            bot.send(chat, "Используй кнопки меню или /start")
    
    except Exception as e:
        print(f"❌ Process: {e}")

def get_updates(offset=None):
    params = {"timeout": 30, "allowed_updates": ["message", "callback_query"]}
    if offset:
        params["offset"] = offset
    
    url = f"https://api.telegram.org/bot{BOT_TOKEN}/getUpdates?{urllib.parse.urlencode(params)}"
    
    try:
        with urllib.request.urlopen(url, timeout=35) as r:
            return json.loads(r.read().decode()).get("result", [])
    except:
        return []

def main():
    print("=" * 40)
    print("🤖 MAX Registration Bot")
    print("=" * 40)
    
    if BOT_TOKEN == "ТВОЙ_ТОКЕН_ОТ_BOTFATHER":
        print("❌ ЗАМЕНИ BOT_TOKEN!")
        return
    
    test = bot.call("getMe")
    if test.get("ok"):
        print(f"✅ @{test['result']['username']} готов!")
    else:
        print("❌ Неверный токен")
        return
    
    print(f"📢 Канал: {CHANNEL_ID}")
    print(f"👥 Группа: {GROUP_ID}")
    print("🚀 Запущен!")
    print("=" * 40)
    
    offset = None
    
    while True:
        try:
            updates = get_updates(offset)
            for u in updates:
                process(u)
                offset = u["update_id"] + 1
            time.sleep(0.3)
        except KeyboardInterrupt:
            print("\n👋 Стоп")
            break
        except Exception as e:
            print(f"❌ {e}")
            time.sleep(5)

if __name__ == "__main__":
    main()
