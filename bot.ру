# ==================== ХРАНИЛИЩЕ ====================
class Data:
    def __init__(self):
        self.file = "data.json"
        self.data = self.load()
    
    def load(self):
        try:
            with open(self.file, "r") as f:
                return json.load(f)
        except:
            return {"users": {}, "regs": []}
    
    def save(self):
        with open(self.file, "w") as f:
            json.dump(self.data, f, indent=2, ensure_ascii=False)
    
    def user(self, uid):
        uid = str(uid)
        if uid not in self.data["users"]:
            self.data["users"][uid] = {"state": "menu", "phone": "", "api": None, "tries": 0}
            self.save()
        return self.data["users"][uid]
    
    def set_user(self, uid, data):
        self.data["users"][str(uid)] = data
        self.save()
    
    def add(self, phone, token, viewer_id, script, uid, name):
        self.data["regs"].append({
            "phone": phone,
            "token": token,
            "viewer_id": viewer_id,
            "script": script,
            "user": name,
            "user_id": uid,
            "time": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        })
        self.save()
    
    def user_regs(self, uid):
        return [r for r in self.data["regs"] if r["user_id"] == uid]

db = Data()

# ==================== TELEGRAM API ====================
class Bot:
    def __init__(self, token):
        self.url = f"https://api.telegram.org/bot{token}"
        self.ssl = ssl.create_default_context()
    
    def call(self, method, data=None):
        try:
            if data:
                data = urllib.parse.urlencode(data).encode()
            req = urllib.request.Request(f"{self.url}/{method}", data=data)
            with urllib.request.urlopen(req, context=self.ssl, timeout=30) as r:
                return json.loads(r.read().decode())
        except Exception as e:
            print(f"❌ TG Error: {e}")
            return {"ok": False}
    
    def send(self, chat, text, **kw):
        d = {"chat_id": chat, "text": text}
        if "kbd" in kw:
            d["reply_markup"] = json.dumps(kw["kbd"])
        if "parse" in kw:
            d["parse_mode"] = kw["parse"]
        return self.call("sendMessage", d)
    
    def edit(self, chat, mid, text, **kw):
        d = {"chat_id": chat, "message_id": mid, "text": text}
        if "kbd" in kw:
            d["reply_markup"] = json.dumps(kw["kbd"])
        if "parse" in kw:
            d["parse_mode"] = kw["parse"]
        return self.call("editMessageText", d)
    
    def subscribed(self, uid):
        try:
            r = self.call("getChatMember", {"chat_id": CHANNEL_ID, "user_id": uid})
            if r.get("ok"):
                return r["result"]["status"] in ["member", "administrator", "creator"]
        except:
            pass
        return False

bot = Bot(BOT_TOKEN)

# ==================== ГЕНЕРАТОР СКРИПТА ====================
def make_script(phone, token, viewer_id):
    """Создает Web-скрипт для входа в MAX"""
    dev_id = str(uuid.uuid4())
    tracer = str(uuid.uuid4())
    
    auth = json.dumps({"token": token, "viewerId": viewer_id})
    theme = json.dumps({"colorScheme": "system", "colorTheme": "space"})
    informer = json.dumps({"lastShowedBannerId": None, "banners": {}})
    
    script = (
        "sessionStorage.clear();"
        "localStorage.clear();"
        'localStorage.setItem("__oneme-persistent-cache-enabled","false");'
        'localStorage.setItem("__oneme_locale","ru");'
        f'localStorage.setItem("__oneme_auth",\'{auth}\');'
        'localStorage.setItem("__server_config_overrides__","{}");'
        f'localStorage.setItem("__oneme_theme",\'{theme}\');'
        f'localStorage.setItem("__oneme_device_id","{dev_id}");'
        f'localStorage.setItem("tracer-device-id","{tracer}");'
        f'localStorage.setItem("__oneme_informer",\'{informer}\');'
        "window.location.reload();"
    )
    
    return script

