def process_update(update):
    try:
        if "message" in update:
            message = update["message"]
            chat_id = message["chat"]["id"]
            
            if "text" in message:
                text = message["text"]
                user_id = message["from"]["id"]
                first_name = message["from"].get("first_name", "User")
                username = message["from"].get("username", "")
                full_name = f"{first_name} {message['from'].get('last_name', '')}".strip()
                
                user = storage.get_user(user_id)
                state = user.get("state", "start")
                
                if text == "/start":
                    handle_start(user_id, chat_id, first_name)
                elif text == "/help":
                    handle_help(chat_id)
                elif text == "/cancel":
                    handle_cancel(user_id, chat_id)
                elif text == "📱 Сдать номер":
                    handle_submit_number_start(user_id, chat_id)
                elif text == "📊 Мои регистрации":
                    handle_show_registrations(user_id, chat_id)
                elif text == "🔑 Web скрипт":
                    handle_web_script(user_id, chat_id)
                elif text == "🔄 Новое устройство":
                    handle_new_device(user_id, chat_id)
                elif text in ["✅ Проверить подписку", "🔄 Проверить подписку"]:
                    handle_check_subscription(user_id, chat_id)
                elif text == "ℹ️ Помощь":
                    handle_help(chat_id)
