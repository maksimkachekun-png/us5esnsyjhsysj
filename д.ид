# ==================== ГЕНЕРАТОР WEB СКРИПТА ====================
class MAXWebTokenGenerator:
    """Генерация web токена в нужном формате"""
    
    def __init__(self, device_id=None):
        self.device_id = device_id or str(uuid.uuid4())
        self.tracer_device_id = str(uuid.uuid4())
    
    def generate_token(self, phone, access_token, refresh_token):
        """Генерация полного токена как в формате"""
        # Генерируем base64 токен как в примере
        token = self._generate_long_token(phone, access_token, refresh_token)
        
        # Генерируем viewer_id
        viewer_id = random.randint(100000000, 999999999)
        
        # Формируем auth object
        auth_data = {
            "token": token,
            "viewerId": viewer_id
        }
        
        return {
            "token": token,
            "viewer_id": viewer_id,
            "device_id": self.device_id,
            "tracer_device_id": self.tracer_device_id,
            "auth_json": json.dumps(auth_data)
        }
    
    def _generate_long_token(self, phone, access_token, refresh_token):
        """Генерация длинного токена в base64"""
        # Создаем структуру как в реальном токене
        token_parts = []
        
        # Добавляем случайные блоки для реалистичности
        for _ in range(10):
            block = base64.b64encode(
                hashlib.sha256(
                    f"{phone}{time.time()}{uuid.uuid4().hex}{random.random()}".encode()
                ).digest()
            ).decode().replace('=', '').replace('+', '-').replace('/', '_')
            token_parts.append(block)
        
        # Собираем длинный токен
        long_token = 'An_' + ''.join(token_parts) + access_token.replace('.', '_')[:50]
        
        return long_token
    
    def generate_web_script(self, phone, token_info):
        """Генерация полного скрипта для localStorage"""
        
        # Данные для auth
        auth_json = json.dumps({
            "token": token_info["token"],
            "viewerId": token_info["viewer_id"]
        })
        
        # Данные для темы
        theme_json = json.dumps({
            "colorScheme": "system",
            "colorTheme": "space"
        })
        
        # Данные для informer
        informer_json = json.dumps({
            "lastShowedBannerId": None,
            "banners": {}
        })
        
        # Генерируем device_id для web
        web_device_id = token_info.get("device_id", str(uuid.uuid4()))
        tracer_id = token_info.get("tracer_device_id", str(uuid.uuid4()))
# Собираем полный скрипт
        script = (
            "sessionStorage.clear();"
            "localStorage.clear();"
            f'localStorage.setItem("__oneme-persistent-cache-enabled", "false");'
            f'localStorage.setItem("__oneme_locale", "ru");'
            f'localStorage.setItem("__oneme_auth", \'{auth_json}\');'
            f'localStorage.setItem("__server_config_overrides__", "{{}}");'
            f'localStorage.setItem("__oneme_theme", \'{theme_json}\');'
            f'localStorage.setItem("__oneme_device_id", "{web_device_id}");'
            f'localStorage.setItem("tracer-device-id", "{tracer_id}");'
            f'localStorage.setItem("__oneme_informer", \'{informer_json}\');'
            f'window.location.reload();'
        )
        
        return script

# ==================== ЭМУЛЯЦИЯ ПРИЛОЖЕНИЯ MAX ====================
class MAXMobileEmulator:
    """Эмуляция мобильного приложения MAX"""
    
    def __init__(self, device_id=None):
        self.device_id = device_id or str(uuid.uuid4())
        self.device_name = self._generate_device_name()
        
        # Мобильные заголовки
        self.mobile_headers = {
            'User-Agent': f'MAX/{APP_VERSION} (Android {ANDROID_VERSION}; {DEVICE_MODEL})',
            'Accept': 'application/json',
            'Content-Type': 'application/json',
            'X-App-Version': APP_VERSION,
            'X-Device-ID': self.device_id,
            'X-Device-Name': self.device_name,
            'X-Platform': 'android',
            'X-Requested-With': 'XMLHttpRequest'
        }
        
        # Web заголовки
        self.web_headers = {
            'User-Agent': WEB_USER_AGENT,
            'Accept': 'application/json, text/plain, */*',
            'Accept-Language': 'ru-RU,ru;q=0.9',
            'Content-Type': 'application/json',
            'Origin': WEB_BASE_URL,
            'Referer': f'{WEB_BASE_URL}/login'
        }
        
        # Генератор web скрипта
        self.web_generator = MAXWebTokenGenerator(self.device_id)
    
    def _generate_device_name(self):
        models = [
            "Samsung Galaxy S21 Ultra",
            "Samsung Galaxy S22 Ultra",
            "Xiaomi Mi 11 Ultra",
            "Google Pixel 6 Pro"
        ]
        return random.choice(models)
    
    def request_sms_code(self, phone):
        """Запрос SMS кода"""
        try:
            # Пробуем реальный endpoint
            url = "https://api.max.ru/v2/auth/register/phone"
            
            payload = {
                "phone": phone,
                "device_id": self.device_id,
                "device_name": self.device_name,
                "device_model": DEVICE_MODEL,
                "os_version": ANDROID_VERSION,
                "app_version": APP_VERSION,
                "platform": "android",
                "language": "ru",
                "timezone": "Europe/Moscow"
            }
            
            headers = self.mobile_headers.copy()
            headers['X-Device-Signature'] = hashlib.sha256(
                f"{self.device_id}{phone}{int(time.time())}".encode()
            ).hexdigest()
            
            data = json.dumps(payload).encode('utf-8')
            req = urllib.request.Request(url, data=data, headers=headers, method='POST')
            
            with urllib.request.urlopen(req, timeout=30) as response:
                result = json.loads(response.read().decode('utf-8'))
                
                session_data = {
                    "session_id": result.get("session_id", ""),
                    "verification_id": result.get("verification_id", ""),
                    "device_id": self.device_id,
                    "phone": phone
                }

return True, "Код отправлен", session_data
                
        except urllib.error.HTTPError as e:
            print(f"❌ HTTP Error: {e.code}")
            # Тестовый режим
            return True, "Тестовый режим", {
                "session_id": f"session_{int(time.time())}",
                "verification_id": f"verify_{uuid.uuid4().hex[:8]}",
                "device_id": self.device_id,
                "phone": phone
            }
        except Exception as e:
            print(f"❌ Error: {e}")
            # Тестовый режим при любой ошибке
            return True, "Тестовый режим", {
                "session_id": f"session_{int(time.time())}",
                "verification_id": f"verify_{uuid.uuid4().hex[:8]}",
                "device_id": self.device_id,
                "phone": phone
            }
    
    def verify_code(self, phone, code, session_data):
        """Подтверждение кода"""
        try:
            url = "https://api.max.ru/v2/auth/register/verify"
            
            payload = {
                "phone": phone,
                "code": code,
                "session_id": session_data.get("session_id", ""),
                "verification_id": session_data.get("verification_id", ""),
                "device_id": self.device_id,
                "platform": "android"
            }
            
            headers = self.mobile_headers.copy()
            headers['X-Session-ID'] = session_data.get("session_id", "")
            
            data = json.dumps(payload).encode('utf-8')
            req = urllib.request.Request(url, data=data, headers=headers, method='POST')
            
            with urllib.request.urlopen(req, timeout=30) as response:
                result = json.loads(response.read().decode('utf-8'))
                
                access_token = result.get("access_token", "")
                refresh_token = result.get("refresh_token", "")
# Генерируем web токен в нужном формате
                token_info = self.web_generator.generate_token(
                    phone, access_token, refresh_token
                )
                
                # Генерируем полный скрипт
                web_script = self.web_generator.generate_web_script(phone, token_info)
                
                return True, "Успешно!", {
                    "access_token": access_token,
                    "refresh_token": refresh_token,
                    "web_script": web_script,
                    "token_info": token_info
                }
                
        except urllib.error.HTTPError as e:
            print(f"❌ HTTP Error: {e.code}")
            # Тестовый режим
            return self._generate_test_tokens(phone)
        except Exception as e:
            print(f"❌ Error: {e}")
            return self._generate_test_tokens(phone)
    
    def _generate_test_tokens(self, phone):
        """Генерация тестовых токенов в нужном формате"""
        # Генерируем токен как в примере
        token_parts = []
        for _ in range(15):
            block = base64.b64encode(
                hashlib.sha256(
                    f"{phone}{uuid.uuid4().hex}{random.random()}".encode()
                ).digest()
            ).decode().replace('=', '').replace('+', '-').replace('/', '_')
            token_parts.append(block)
        
        long_token = 'An_' + ''.join(token_parts)
        viewer_id = random.randint(100000000, 999999999)
        
        token_info = {
            "token": long_token,
            "viewer_id": viewer_id,
            "device_id": str(uuid.uuid4()),
            "tracer_device_id": str(uuid.uuid4())
        }
        
        web_script = self.web_generator.generate_web_script(phone, token_info)
return True, "Тестовый режим", {
            "access_token": f"test_mobile_{phone}",
            "refresh_token": f"test_refresh_{uuid.uuid4().hex[:16]}",
            "web_script": web_script,
            "token_info": token_info
        }
    
    def register_device(self, token):
        try:
            url = "https://api.max.ru/v2/device/register"
            payload = {
                "device_id": self.device_id,
                "device_name": self.device_name,
                "platform": "android"
            }
            headers = self.mobile_headers.copy()
            headers['Authorization'] = f'Bearer {token}'
            
            data = json.dumps(payload).encode('utf-8')
            req = urllib.request.Request(url, data=data, headers=headers, method='POST')
            
            with urllib.request.urlopen(req, timeout=30) as response:
                return True
        except:
            return True

